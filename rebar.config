{erl_opts, [
    debug_info,           %% required for Dialyzer
    warnings_as_errors    %% enforce clean code; no warnings slip through
]}.

{deps, [
    %% HTTP server
    {cowboy, "2.12.0"},

    %% JSON encode/decode
    {jsone, "1.8.0"},

    %% UUID generation for all entity IDs
    {uuid, "2.0.0", {pkg, uuid_erl}},

    %% Property-based testing (also needed at runtime for test profiles)
    {proper, "1.4.0"}
]}.

%% All apps live under apps/
{project_plugins, [rebar3_proper]}.

{profiles, [
    {test, [
        {deps, [
            {proper, "1.4.0"}
        ]},
        {erl_opts, [
            debug_info,
            nowarn_export_all   %% test suites often use export_all
        ]}
    ]}
]}.

%% Dialyzer — analyse all project apps plus key deps
{dialyzer, [
    {warnings, [
        unmatched_returns,
        error_handling,
        underspecs
    ]},
    {plt_apps, top_level_deps},
    {plt_extra_apps, [mnesia, crypto, uuid, ranch]}
]}.

%% Common Test output directory
{ct_opts, [
    {logdir, "_build/test/logs"}
]}.

%% PropEr options (overridden per-run with --numtests flag)
{proper_opts, [
    {numtests, 100}
]}.

%% Tell rebar3 where the apps are
{project_app_dirs, ["apps/*"]}.

%% Erlang release configuration (for rebar3 shell / rebar3 release)
{relx, [
    {release, {ironledger, "0.1.0"}, [
        {cb_integration, permanent},
        {cb_auth, temporary},
        {cb_approvals, temporary},
        {cb_channels, temporary},
        {cb_currency, temporary},
        {cb_events, temporary},
        {cb_reporting, temporary},
        {cb_accounts, temporary},
        {cb_ledger, temporary},
        {cb_savings_products, temporary},
        {cb_interest, temporary},
        {cb_loans, temporary},
        {cb_payments, temporary},
        {cb_party, temporary},
        {cb_compliance, temporary},
        {sasl, permanent}
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"}
]}.

%% Shell config — loads sys.config and starts all apps
{shell, [
    {config, "config/sys.config"},
    {apps, [cb_integration]}  %% cb_integration starts everything via dependencies
]}.
